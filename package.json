{
    "name": "try-in-web-ide",
    "version": "1.0.0",
    "description": "Try in Web IDE",
    "repository": {
        "type": "git",
        "url": "https://github.com/redhat-actions/try-in-web-ide"
    },
    "author": "Red Hat",
    "license": "MIT",
    "scripts": {
        "compile": "tsc -p .",
        "bundle": "npx ncc build src/index.ts --source-map --minify",
        "clean": "rm -rf out/ dist/",
        "lint": "eslint . --max-warnings=0",
        "test": "jest"
    },
    "jest": {
        "collectCoverage": true,
        "collectCoverageFrom": [
            "src/**/*.ts"
        ],
        "coverageDirectory": "./coverage",
        "transform": {
            "^.+\\.[jt]sx?$": ["ts-jest", { "useESM": false }]
        },
        "transformIgnorePatterns": [
            "node_modules/(?!(inversify|@inversifyjs|@actions/github|@actions/core|@octokit)/)"
        ],
        "modulePathIgnorePatterns": [
            "<rootDir>/out"
        ],
        "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
        "moduleFileExtensions": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "json"
        ]
    },
    "devDependencies": {
        "@redhat-actions/action-io-generator": "^1.5.0",
        "@redhat-actions/eslint-config": "^1.3.2",
        "@redhat-actions/tsconfig": "^1.2.0",
        "@types/fs-extra": "^9.0.12",
        "@types/jest": "^29.5.0",
        "@types/node": "^20",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vercel/ncc": "^0.44.1",
        "eslint": "^8.57.0",
        "eslint-plugin-jest": "^29.0.0",
        "fs-extra": "^10.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.0",
        "typescript": "^5.8.0"
    },
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1",
        "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
        "inversify": "^8.1.1",
        "reflect-metadata": "~0.2.2"
    }
}
